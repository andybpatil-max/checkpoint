<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <description>Checkpoint Spring Boot Application</description>
    <display-name>Checkpoint</display-name>

    <!-- ========================================================= -->
    <!-- Servlet Context Listener                                   -->
    <!-- ========================================================= -->
    <listener>
        <listener-class>com.webfiche.checkpoint.actions.EcontServletContextListener</listener-class>
    </listener>

    <!-- ========================================================= -->
    <!-- Database Initialization Servlet (load-on-startup=1)       -->
    <!-- Reads DB config, checks tables, loads system_control,     -->
    <!-- starts background file-server threads (Phase F)           -->
    <!-- ========================================================= -->
    <servlet>
        <servlet-name>database</servlet-name>
        <servlet-class>com.webfiche.checkpoint.DatabaseServlet</servlet-class>

        <init-param><param-name>driverclassname</param-name>
            <param-value>oracle.jdbc.driver.OracleDriver</param-value></init-param>
        <init-param><param-name>dburl</param-name>
            <param-value>jdbc:oracle:thin:@10.0.0.155:1521:ORCLCDB</param-value></init-param>
        <init-param><param-name>releaseVersion</param-name>
            <param-value>Production v5.1.001</param-value></init-param>
        <init-param><param-name>appSchema</param-name>
            <param-value>INCL</param-value></init-param>
        <init-param><param-name>user</param-name>
            <param-value>C##INCL</param-value></init-param>
        <init-param><param-name>uPort</param-name>
            <param-value>12100</param-value></init-param>
        <init-param><param-name>nodename</param-name>
            <param-value>esl</param-value></init-param>
        <init-param><param-name>dbused</param-name>
            <param-value>ORACLE</param-value></init-param>
        <init-param><param-name>reportHdg</param-name>
            <param-value>COMMERZBANK AG NEW YORK</param-value></init-param>
        <init-param><param-name>minSizePw</param-name>
            <param-value>8</param-value></init-param>
        <init-param><param-name>numPastPw</param-name>
            <param-value>10</param-value></init-param>
        <init-param><param-name>numTrysPw</param-name>
            <param-value>5</param-value></init-param>
        <init-param><param-name>bankId</param-name>
            <param-value>CBKNY</param-value></init-param>
        <init-param><param-name>fastAxsNum</param-name>
            <param-value>20</param-value></init-param>
        <init-param><param-name>smtpDomain</param-name>
            <param-value>mail.exacthosting.com</param-value></init-param>
        <init-param><param-name>imagesPerPDF</param-name>
            <param-value>100</param-value></init-param>
        <init-param><param-name>checksPerView</param-name>
            <param-value>500</param-value></init-param>
        <init-param><param-name>imageURL</param-name>
            <param-value>/imagedir/</param-value></init-param>
        <init-param><param-name>fromEmailAddress</param-name>
            <param-value>Andy.Patil@webFiche.com</param-value></init-param>
        <init-param><param-name>stmtSubject</param-name>
            <param-value>Account Statement</param-value></init-param>
        <init-param><param-name>stmtMsgDir</param-name>
            <param-value>/usr/local/econtr/ny/</param-value></init-param>
        <init-param><param-name>fourIsVerify</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>sysAlertEmail</param-name>
            <param-value>andybpatil@gmail.com</param-value></init-param>
        <init-param><param-name>checkPointIn</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>checkPointOutLockBox</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>checkPointRemote</param-name>
            <param-value>N</param-value></init-param>
        <init-param><param-name>flowPoint</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>netPoint</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>infoPoint</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>mdPoint</param-name>
            <param-value>Y</param-value></init-param>
        <init-param><param-name>mandatePoint</param-name>
            <param-value>N</param-value></init-param>
        <init-param><param-name>extDelimiter</param-name>
            <param-value>&#9;</param-value></init-param>
        <init-param><param-name>daysCheckValid</param-name>
            <param-value>180</param-value></init-param>
        <init-param><param-name>batchPgm</param-name>
            <param-value>CheckTiff2Xml.exe</param-value></init-param>
        <init-param><param-name>batchForm</param-name>
            <param-value>/opt/checkpoint/batch/NewCheck1.xpbd</param-value></init-param>
        <init-param><param-name>batchTiffs</param-name>
            <param-value>/opt/checkpoint/batch/img</param-value></init-param>
        <init-param><param-name>contentRoot</param-name>
            <param-value>/opt/infopoint/</param-value></init-param>
        <init-param><param-name>textFiles</param-name>
            <param-value>@ascii@dat@data@err@form@java@log@map@out@prt@rpt@rep@spl@spool@txt@text@vb@</param-value></init-param>
        <init-param><param-name>debugFlag</param-name>
            <param-value>N</param-value></init-param>

        <load-on-startup>1</load-on-startup>
    </servlet>

</web-app>
