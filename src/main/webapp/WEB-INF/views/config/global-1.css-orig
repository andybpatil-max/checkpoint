/************ *   link   * ***********/A          {color : blue; }A:Visited  {color : orange; }A:Active   {color : blue; }A:Hover    {color : darkgreen;	    background-color: lightgreen;	    text-decoration : none; }/*********************//* BASIC             *//*********************/html,body {    height: 100%;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;    padding-left:60px;/*    margin-left: 60px;*/    background-color: #FFFFFF;}p,h1,h2,h3,h4,h5,h5 {    margin: 0px;    padding: 0px;}br.clear {    height:1px;    clear:both;    line-height: 1px;    background-color: #00CC33;}table {     border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;    margin-bottom: 20px;}td {    background-color: #eef0f3; /* #98adc2; /*lightyellow;*/    font-size: .8em;    border: 1px solid black;    padding: 3px 5px 2px 5px;    text-align: center;}th {background: url(gifs/th_bg2.png) repeat-x left top;    background-color: #d6e0eb; /* #98adc2; /*lightyellow;*/    color:black;    text-align: center;    font-size: .8em;    border: 1px solid black;    border-color: #14556b;    padding: 6px 10px 4px 10px;}td,th {	border: 1px solid #73afb7;	padding: 3px 5px 2px 5px;	font-size: .8em;}th.header {	text-align: center;}/*********************************************** * color of the thin line surrounding the form * **********************************************/TABLE.FORM {	width: auto;	text-align : center;	background-color : #000000;}/************************************** * background color of the form title * *************************************/TH.FORM {	text-align : center;	color      : black;	background-color : turquoise;	font-weight: bold;}/******************************** * background color of the form  #336699* *******************************/TD.FORM {	text-align : center;	background-color :   #eef0f3;	font-size : 1.0em;}a:hover {    text-decoration: none;    background-color:lightgreen;}#help {    width: 1024;}#help td, ul, li {    text-align: left;}h1 {    text-align: center;    font-size: 1.1em}    h1.start {    text-align: center;    font-size: 1.1em;    margin-left: 200px;}h2 {    text-align: center;    font-size: .7em}    /*********************//* LAYOUT *//*********************/#wrapper {    width: 1024px;    min-height: 100%;    position:relative;/*  border-right-width: 1px;    border-right-style: solid;    border-right-color: #999999; */}#maino {    border-right: 1px solid #999999;    border-left: 1px solid #999999;    padding: 3px 3px 0 6px;    float: left;    width: 424px;}#main {    min-height: 100%;    padding: 3px 3px 0px 6px;    width: 1024px;    margin-left: 0px;    margin-top: -5px;    position:relative;    /*overflow:auto;	scroll;*/}#main-f {    min-height: 100%;    position:relative;    margin-bottom:-250px;/*    padding: 3px 3px 0px 6px;    width: 1024px;    margin-left: 0px;    margin-top: -5px;    overflow:scroll;*/}#body-p {   padding-bottom:250px;   /* Height of the footer */}#mainx {    padding-bottom:300px;    }/*#main p {    margin-bottom: 10px;}*/#main1 {    padding: 3px 3px 0 6px;    width: auto;    margin-left: 300px;}#main2 {    padding: 3px 3px 0 6px;    width: 1024px;    margin-top: 20px;}#main2 table {     border-collapse: collapse;    width: 220px;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;    margin-bottom: 20px;}#main2 th {    width: 100px;    text-align:right;}#main2 td {    text-align:left;    width: auto;}/* Detail Table Entries */#detail table {    border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;}#detail th {    background: url(gifs/thbg-green1.png) repeat-x left top;    width: auto;    text-align:right;}#detail th.header {    width: auto;    text-align:center;}#detail td {    text-align:left;    width: auto;}/* Selection result rows */#selres table {    border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;}#selres th {    width: auto;    text-align:left;}#selres th.header {    width: auto;    text-align:center;}#selres td {    text-align:left;    width: auto;}/* Reject Codes Explained */#rejcodes table {    border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;}#rejcodes th {    width: auto;    text-align:left;}#rejcodes td {    text-align:left;    font-size: .9em;    font-weight: bold;    width: auto;}/* Totals */#totals table {    border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;}#totals th {    width: auto;    text-align:left;}#totals td {    text-align:right;    font-size: .8em;    width: auto;}/* summary */#summary table {    border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;}#summary th {    width: auto;    text-align:left;}#summary th.header {    width: auto;    text-align:center;}#summary td {    text-align:right;    font-size: .8em;    width: auto;}#summary td.red {    background-color: red;    text-align:right;    font-size: .8em;    font-color: white;    width: auto;}#summary td.orange {    background-color: orange;    text-align:right;    font-size: .8em;    font-color: white;    width: auto;}#summary td.lightgreen {    background-color: lightgreen;    text-align:right;    font-size: .8em;    font-color: black;    width: auto;}#summary td.yellow {    background-color: yellow;    text-align:right;    font-size: .8em;    font-color: black;    width: auto;}#summary td.skyblue {    background-color: skyblue;    text-align:right;    font-size: .8em;    font-color: black;    width: auto;}#errors li {    list-style: none;    font-size: .9em;    text-align: center;/*    padding-left: 10;    margin-left: -40; */}#banner {    background-image: url(gifs/banner-econtr.png);/*    background-image: url(gifs/logo_image-7.jpg);    background-image: url(gifs/logo_image-8.jpg); */    background-repeat: no-repeat;    background-position: right top;    width: 1024px;/*  border-bottom: 1px solid #999999;    margin-bottom: 1px; */}#copyright {    clear: both;    margin-left: 150px;    border: 1px solid #999999;    border-right:none;    font-size: 12px;    padding-left: 6px;}/*********************//* BANNER STYLES     *//*********************/#background {    background-image: url(gifs/logo_image-5.jpg);    background-repeat: no-repeat;    background-position: left top;}/* image replacement technique */#banner p.logo {/*  background: url(images/logo.gif) no-repeat left top;    background: url(gifs/wf_transparent_4.gif) no-repeat left top;  */    background: url(gifs/wf_transparent_3.gif) no-repeat left top;    height: 80px;    text-indent: -5000px;/*    margin-bottom: 2px; */}/**********************//* MAIN SECTION STYLES*//**********************/#main td {	width: auto;}#main h1 {    color: #5F9794;    font: bold 22px "Century Gothic", "Gill Sans", Arial, sans-serif;    text-align: center;}/*#main h1.medium {    color: #5F9794;    font: bold 20px "Century Gothic", "Gill Sans", Arial, sans-serif;    background-color: silver;    margin-left: 240px;    margin-right: 240px;    text-align: center;}#main1 h1 {    color: #5F9794;    font: bold 20px "Century Gothic", "Gill Sans", Arial, sans-serif;    text-align: center;}#main1 a {    text-decoration: none;    background-image: url(gifs/reportAccess.gif);    background-repeat: no-repeat;    background-position: center center;    text-indent: -9999;    display: block;    height: 40px;    width: 40px;}#main1 a.cal {    text-decoration: none;    background-image: url(gifs/calendarAccess.gif);    background-repeat: no-repeat;    background-position: center center;    text-indent: -9999;    display: block;    height: 40px;    width: 40px;}#main1 a:hover {    text-decoration: none;    background-image: url(gifs/openReportAccess.gif);    background-repeat: no-repeat;}#main1 a.cal:hover {    text-decoration: none;    background-image: url(gifs/openCalendarAccess.gif);    background-repeat: no-repeat;}#main1 table {     border-collapse: collapse;    width: 700px;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;    margin-bottom: 20px;}#main1 table.thin {     border-collapse: collapse;    width: auto;    font-family: "Century Gothic", "Gill Sans", Arial, sans-serif;    margin-bottom: 20px;}#nav {    float: left;    width: 280px;    display: block;    margin-left: 0;    clear: left;}*/* html #main1 {margin-left:0; }* html #nav #mainNav {margin-right: -3px; }#mainNav li {    list-style: none;    font-size: .6em;    padding-left: 10;    margin-left: -40;}#mainNav h1 {    border-bottom: 1px solid #999999;    background-color: #d6e0eb; /*lightyellow;*/    font-size: 1.1em;/*  top right bottom left */    padding: 4px 5px 4px 5px;    margin-left: -0px;}#mainNav h2 {    border-bottom: 1px solid #999999;    background-color: #d6e0eb; /* #98adc2; */    font-size: .8em;/*  top right bottom left */    padding: 4px 5px 4px 5px;    margin-left: -0px;}#mainNav a {    text-decoration: none;    color: #000000;    font-size: 1.1em;    border-bottom: 1px solid #999999;    display: block;    margin-top: 0px;    margin-bottom: 0px;/*  padding: 1px 5px 1px 10px; *//*  top right bottom left */    padding: 0px 5px 0px 5px;    margin-left: -0px;}#mainNav ul {    border-top: 1px solid #999999;    border-left: 1px solid #999999;    border-right: 1px solid #999999;    margin-top: 20px;    margin-bottom: 10px;    margin-left: -1px;    padding-left: -20px;    display: block;    background-color: #eef0f3; /*lightgrey;*/}#mainNav a:hover {    padding-right: 5px;    padding-left: -10px;    font-weight: bold;}#home #mainNav a#homelink:hover,#feature #mainNav a#featureLink:hover {    color: #B2F511;}#nav p {    color: #ED6733;    padding-right: 5px;    padding-left: 5px;}#nav a {    text-decoration: none;    color: #666666;}#ft {    zoom:1;}#ft {border-top:5px solid #d3ecfb;text-align:left;background:#e8f5fd;padding:15px 0;}.cols {margin-bottom:30px;}.col {float:left;display:inline;width:20%;}#ieonly #ft div.cols div.col {width:19.950001%;}*/.yui-b {position:static;float:none;width:auto;}* html .clearfix,* html .sfBox {height:1%;}.clearfix {display:inline-block;}li {list-style:none;}ul.listCol li div.col {float:left;display:inline-block;margin-left:-60px;}